{
  "county": "san_bernardino",
  "platform": "playwright_form",
  "base_url": "https://www.sbcountyatc.gov/tax-services/property-tax",
  "authoritative_source_hosts": ["gsgprod.sbcountyatc.gov"],
  "host_whitelist_mode": "strict",
  "headless": false,
  "min_delay_seconds": 1,
  "default_timeout_ms": 45000,
  "no_results_patterns": [
    "no\\s+matching\\s+account",
    "no\\s+results\\s+found",
    "account\\s+not\\s+found",
    "parcel\\s+not\\s+on\\s+file"
  ],
  "_iframe_topology": "Page tree: www.sbcountyatc.gov (top) -> iframe#gsg-public-site -> gsgprod.sbcountyatc.gov (level 1; hosts the typeahead search). After the user picks a suggestion the gsgprod frame navigates to a /<base64-account>/ URL and **injects** a child iframe pointing at /iframe-taxsys/sanbernardino-ca.county-taxes.com/govhub/property-tax/...; that inner frame's host is also gsgprod.sbcountyatc.gov (the iframe-taxsys path is rewritten / reverse-proxied). Clicking that inner frame's 'Bill Details' link (a[href*='bills']) navigates the inner frame to the per-bill page that exposes the assessed-value + installment data we extract.",
  "_known_artifact": "Typeahead input has a dynamic id like 'typeahead-input-79095' — match it via prefix selector (input[id^='typeahead-input-']). Suggestion list items use role='option'.",
  "navigation_steps": [
    {
      "action": "goto",
      "url": "https://www.sbcountyatc.gov/tax-services/property-tax",
      "settle_ms": 8000,
      "timeout_ms": 45000
    },
    {
      "action": "enter_frame",
      "selector": "iframe#gsg-public-site, iframe[src*='gsgprod.sbcountyatc.gov']",
      "url_contains": "gsgprod.sbcountyatc.gov",
      "timeout_ms": 25000,
      "settle_ms": 2000
    },
    {
      "action": "fill",
      "selector": "input[id^='typeahead-input-']",
      "value": "{apn}",
      "timeout_ms": 25000
    },
    {
      "action": "sleep",
      "ms": 3500
    },
    {
      "action": "click",
      "selector": "[role='option']",
      "timeout_ms": 20000,
      "settle_ms": 6000
    },
    {
      "action": "wait_for",
      "selector": "iframe[src*='iframe-taxsys']",
      "state": "attached",
      "timeout_ms": 30000
    },
    {
      "action": "enter_frame",
      "selector": "iframe[src*='iframe-taxsys']",
      "url_contains": "iframe-taxsys",
      "timeout_ms": 25000,
      "settle_ms": 2000
    },
    {
      "action": "click",
      "selector": "a[href*='/bills/']",
      "timeout_ms": 20000,
      "settle_ms": 5000,
      "optional": true
    },
    {
      "action": "wait_for",
      "selector": "text=/Total\\s+Tax|Total\\s+Taxable\\s+Value|NET\\s+ASSESSED\\s+VALUE/i",
      "state": "visible",
      "timeout_ms": 20000,
      "optional": true
    }
  ],
  "output_mode": "html",
  "extract": {
    "apn": {
      "regex": "Account\\s+([0-9]{13})",
      "scope": "body"
    },
    "tax_year": {
      "regex": "Fiscal\\s+Year:?\\s*(\\d{4}-\\d{2})",
      "scope": "body"
    },
    "tra": {
      "regex": "Tax\\s+Rate\\s+Area:?\\s*([0-9]{3}-[0-9]{3})",
      "scope": "body"
    },
    "property_address": {
      "regex": "Address:\\s*\\n?\\s*([0-9A-Z][0-9A-Z .,#/-]+?)(?:\\n|$)",
      "scope": "body"
    },
    "assessed_value.land": {
      "regex": "Land:\\s*\\$?([0-9,]+)",
      "scope": "body",
      "type": "currency"
    },
    "assessed_value.improvements": {
      "regex": "Improvements:\\s*\\$?([0-9,]+)",
      "scope": "body",
      "type": "currency"
    },
    "assessed_value.exemptions": {
      "regex": "Homeowners\\s+Exemption:\\s*\\$?([0-9,]+)",
      "scope": "body",
      "type": "currency"
    },
    "assessed_value.net_taxable": {
      "regex": "Total\\s+Taxable\\s+Value:\\s*\\n?\\s*\\$([0-9,]+\\b)",
      "scope": "body",
      "type": "currency"
    },
    "annual_total": {
      "regex": "Total\\s+Tax:\\s*\\$?([0-9,]+\\.\\d{2})",
      "scope": "body",
      "type": "currency"
    },
    "installments[0].label": {
      "regex": "(1st Installment)",
      "scope": "body"
    },
    "installments[0].amount": {
      "regex": "1st Installment[\\s\\S]{0,200}?(?:PAID|UNPAID|DELINQUENT)\\s*\\$?([0-9,]+\\.\\d{2})",
      "scope": "body",
      "type": "currency"
    },
    "installments[0].status": {
      "regex": "1st Installment[\\s\\S]{0,200}?(PAID|UNPAID|DELINQUENT)",
      "scope": "body"
    },
    "installments[1].label": {
      "regex": "(2nd Installment)",
      "scope": "body"
    },
    "installments[1].amount": {
      "regex": "2nd Installment[\\s\\S]{0,200}?(?:PAID|UNPAID|DELINQUENT)\\s*\\$?([0-9,]+\\.\\d{2})",
      "scope": "body",
      "type": "currency"
    },
    "installments[1].status": {
      "regex": "2nd Installment[\\s\\S]{0,200}?(PAID|UNPAID|DELINQUENT)",
      "scope": "body"
    }
  },
  "verification_required": [
    "assessed_value.net_taxable",
    "annual_total",
    "installments[0].amount",
    "installments[1].amount"
  ]
}
